{
  "name": "yida-electron-self-login",
  "version": "2.0.0",
  "description": "宜搭 Windows 自助登录工具（V2 生产授权版：RS256 + pbkdf2）",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:dir": "electron-builder --dir",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win portable",
    "build:linux": "electron-builder --linux"
  },
  "dependencies": {
    "axios": "^1.7.9",
    "jsonwebtoken": "^9.0.2",
    "node-machine-id": "^1.1.12"
  },
  "devDependencies": {
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "javascript-obfuscator": "^4.1.1"
  },
  "build": {
    "appId": "com.bunnyhan.yida.selflogin",
    "productName": "宜搭自助登录",
    "asar": true,
    "files": [
      "main.js",
      "preload.js",
      "renderer.html",
      "renderer.js",
      "src/**/*",
      "keys/**/*",
      "package.json"
    ],
    "directories": {
      "output": "dist"
    },
    "mac": {
      "target": "dmg"
    },
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "yida-self-login-${version}-${arch}.${ext}"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
