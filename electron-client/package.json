{
  "name": "yida-electron-self-login",
  "version": "2.0.0",
  "description": "宜搭自助登录工具",
  "author": "openyidalogin",
  "main": "main.js",
  "config": {
    "authServer": "",
    "storageSecret": ""
  },
  "scripts": {
    "start": "electron .",
    "check:build-config": "node scripts/validate-build-config.js",
    "build:dir": "node scripts/validate-build-config.js && electron-builder --dir",
    "build:mac": "node scripts/validate-build-config.js && electron-builder --mac --x64 --arm64",
    "build:mac:x64": "node scripts/validate-build-config.js && electron-builder --mac --x64",
    "build:mac:arm64": "node scripts/validate-build-config.js && electron-builder --mac --arm64",
    "build:win": "node scripts/validate-build-config.js && electron-builder --win portable --x64",
    "build:win:x64": "node scripts/validate-build-config.js && electron-builder --win portable --x64",
    "build:linux": "node scripts/validate-build-config.js && electron-builder --linux AppImage deb --x64",
    "build:linux:x64": "node scripts/validate-build-config.js && electron-builder --linux AppImage deb --x64"
  },
  "dependencies": {
    "axios": "^1.7.9",
    "jsonwebtoken": "^9.0.2",
    "node-machine-id": "^1.1.12"
  },
  "devDependencies": {
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "javascript-obfuscator": "^4.1.1"
  },
  "build": {
    "appId": "com.openyidalogin.yida.selflogin",
    "productName": "宜搭自助登录",
    "asar": true,
    "files": [
      "main.js",
      "preload.js",
      "renderer.html",
      "renderer.js",
      "src/**/*",
      "keys/**/*",
      "package.json"
    ],
    "directories": {
      "output": "dist"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "artifactName": "yida-self-login-${version}-${arch}.${ext}"
    },
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "yida-self-login-${version}-${arch}.${ext}"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Utility",
      "artifactName": "yida-self-login-${version}-${arch}.${ext}"
    }
  }
}
